{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Disposable Email Infrastructure Provider",
  "type": "object",
  "required": [
    "slug",
    "type",
    "key",
    "label",
    "domain_count",
    "source_domain_count",
    "mx_hosts",
    "mx_ipv4",
    "mx_ipv6"
  ],
  "additionalProperties": false,
  "properties": {
    "slug": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "key": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "domain_count": {
      "type": "integer"
    },
    "source_domain_count": {
      "type": "integer"
    },
    "mx_hosts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mx_ipv4": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mx_ipv6": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "first_seen_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_seen_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "last_enriched_at": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
